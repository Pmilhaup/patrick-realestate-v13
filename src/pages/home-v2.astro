---
// HOMEPAGE PROTOTYPE — the 8-movement narrative per _audit-2026-07/04_HOMEPAGE_REDESIGN.md
// Preview route only (noindexed). On approval this becomes index.astro.
// Uses brand-core (the new gold) throughout.
import Chapter from '../layouts/Chapter.astro';
const lds = [{
  "@context":"https://schema.org","@type":"RealEstateAgent","@id":"https://patrick.realestate/#agent",
  "name":"Patrick Milhaupt","url":"https://patrick.realestate/",
  "image":"https://patrick.realestate/images/patrick-headshot.jpg",
  "telephone":"+1-847-849-9828","email":"pmilhaupt@jamesonsir.com","jobTitle":"Global Advisor",
  "worksFor":{"@type":"RealEstateAgent","name":"Jameson Sotheby's International Realty"}
}];
---
<Chapter
  title="Patrick Milhaupt — A North Shore Practice"
  description="Institutional discipline, applied to the North Shore's most significant homes. The market read daily; homes introduced carefully."
  path="/home-v2" current="" palette="0.40"
  jsonLd={lds[0]}
  rail={[]}
>
  <meta slot="head" name="robots" content="noindex">
  <link slot="head" rel="stylesheet" href="/brand/brand-core.css">
  <style slot="head" is:global>
  /* ── home-v2: movement styles on brand-core tokens ── */
  .mv { min-height: 92vh; display: flex; align-items: center; padding: 96px 0; }
  .mv .inner { width: min(1080px, calc(100% - 48px)); margin: 0 auto; }
  .mv-eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: .25em;
    text-transform: uppercase; color: var(--gold-400); display: block; margin-bottom: 22px; }
  .mv h1, .mv h2 { font-family: var(--font-serif); font-weight: 300; color: var(--ink-1);
    letter-spacing: -0.02em; line-height: 1.08; margin: 0 0 20px; }
  .mv h1 { font-size: clamp(46px, 7vw, 96px); }
  .mv h2 { font-size: clamp(32px, 4.2vw, 54px); }
  .mv h1 em, .mv h2 em { font-style: italic; color: var(--gold-200); }
  .mv .lede { font-family: var(--font-sans); font-weight: 300; font-size: 17px; line-height: 1.65;
    color: var(--ink-3); max-width: 560px; }
  .mv .lede strong { color: var(--ink-2); font-weight: 500; }
  .mv-rule { width: 56px; height: 1px; background: var(--gold-400); margin: 28px 0; border: 0; }
  .mv-link { font-family: var(--font-mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase;
    color: var(--gold-300); text-decoration: none; border-bottom: 1px solid var(--gold-500);
    padding-bottom: 4px; transition: color var(--t-fast) var(--ease-inout), border-color var(--t-fast) var(--ease-inout); }
  .mv-link:hover, .mv-link:focus-visible { color: var(--gold-100); border-color: var(--gold-300); }

  /* Movement 0 — arrival */
  #mv0 { min-height: 100vh; text-align: center; }
  #mv0 .inner { display: flex; flex-direction: column; align-items: center; }
  .scroll-cue { margin-top: 56px; font-family: var(--font-mono); font-size: 10px; letter-spacing: .3em;
    text-transform: uppercase; color: var(--ink-4); }
  .scroll-cue::after { content: ""; display: block; width: 1px; height: 42px;
    background: linear-gradient(var(--gold-400), transparent); margin: 14px auto 0; }

  /* Movement 1 — this morning's market */
  .kpi-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin: 36px 0 10px; }
  @media (max-width: 720px) { .kpi-row { grid-template-columns: 1fr; } }
  .kpi2 { background: var(--navy-1); border: 1px solid rgba(194,162,101,.22); border-radius: 10px; padding: 22px 24px; }
  .kpi2 .l { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .2em; text-transform: uppercase; color: var(--ink-4); }
  .kpi2 .v { font-family: var(--font-mono); font-weight: 500; font-size: clamp(26px, 2.6vw, 36px);
    color: var(--ink-1); letter-spacing: -0.02em; display: block; margin-top: 10px; font-variant-numeric: tabular-nums; }
  .kpi2 .d { font-family: var(--font-sans); font-size: 12px; color: var(--ink-3); display: block; margin-top: 8px; }
  .spark-wrap { margin-top: 18px; background: var(--navy-1); border: 1px solid rgba(194,162,101,.16);
    border-radius: 10px; padding: 18px 22px 10px; }
  .spark-wrap .l { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .2em; text-transform: uppercase; color: var(--ink-4); }
  #spark { width: 100%; height: 64px; display: block; margin-top: 8px; }
  .asof { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .12em; color: var(--ink-4);
    text-transform: uppercase; margin-top: 16px; display: inline-block; }
  .asof b { color: var(--gold-300); font-weight: 500; }

  /* Movement 2 — who */
  .who-grid { display: grid; grid-template-columns: 200px 1fr; gap: 44px; align-items: center; }
  @media (max-width: 720px) { .who-grid { grid-template-columns: 1fr; } }
  .who-grid img { width: 200px; height: 240px; object-fit: cover; border-radius: 8px;
    border: 1px solid rgba(194,162,101,.3); filter: saturate(.92); }

  /* Movement 3 — how */
  .steps-rail { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 34px; }
  @media (max-width: 900px) { .steps-rail { grid-template-columns: 1fr; } }
  .step2 { border-top: 1px solid rgba(194,162,101,.3); padding: 16px 4px 0; }
  .step2 .n { font-family: var(--font-mono); font-size: 10px; letter-spacing: .2em; color: var(--gold-400); }
  .step2 .t { font-family: var(--font-serif); font-size: 19px; color: var(--ink-1); margin-top: 8px; }

  /* Movement 5 — proof */
  .press2 { border-left: 1px solid rgba(194,162,101,.4); padding-left: 20px; margin-bottom: 22px; }
  .press2 .q { font-family: var(--font-serif); font-size: 20px; line-height: 1.45; color: var(--ink-1); }
  .press2 .s { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .16em; text-transform: uppercase;
    color: var(--ink-3); margin-top: 8px; }
  .outcome { font-family: var(--font-mono); font-size: 13px; color: var(--ink-2); letter-spacing: .02em;
    background: var(--navy-1); border: 1px solid rgba(194,162,101,.2); border-radius: 8px;
    padding: 16px 20px; display: inline-block; margin-bottom: 30px; }
  .outcome b { color: var(--gold-200); font-weight: 500; }

  /* Movement 6 — where */
  .villages2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 4px 40px; margin-top: 30px; }
  .villages2 a, .villages2 span { display: flex; justify-content: space-between; align-items: baseline;
    padding: 14px 2px; border-bottom: 1px solid rgba(194,162,101,.16); text-decoration: none; }
  .villages2 .vn { font-family: var(--font-serif); font-size: 21px; color: var(--ink-1);
    transition: color var(--t-fast) var(--ease-inout); }
  .villages2 a:hover .vn { color: var(--gold-200); }
  .villages2 .vd { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .1em;
    text-transform: uppercase; color: var(--ink-4); }

  /* Movement 7 — invitation */
  #mv7 { text-align: center; }
  #mv7 .inner { display: flex; flex-direction: column; align-items: center; }
  .invite-row { display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; margin-top: 34px; }
  .invite-btn { font-family: var(--font-mono); font-size: 11.5px; letter-spacing: .16em; text-transform: uppercase;
    color: var(--gold-200); text-decoration: none; border: 1px solid var(--gold-500); border-radius: 6px;
    padding: 15px 28px; transition: border-color var(--t-fast) var(--ease-inout), background var(--t-fast) var(--ease-inout); }
  .invite-btn:hover, .invite-btn:focus-visible { border-color: var(--gold-300); background: rgba(194,162,101,.08); }
  .invite-btn.solid { background: var(--gold-400); color: #10182B; border-color: var(--gold-400); font-weight: 600; }
  .invite-btn.solid:hover { background: var(--gold-300); }

  @media (prefers-reduced-motion: reduce) { .scroll-cue::after { display: none; } }
  </style>

  <!-- ═══ 0 · ARRIVAL — no splash; the reveal is the arrival ═══ -->
  <section class="chapter mv" id="mv0" data-chapter="0" data-palette="0.25">
    <div class="inner">
      <span class="mv-eyebrow fade-up">Patrick Milhaupt &middot; Jameson Sotheby's International Realty</span>
      <h1 class="headline" data-headline="">Institutional discipline,<br>applied to homes of <em>consequence</em>.</h1>
      <p class="lede fade-up" style="margin: 0 auto; text-align: center;">
        The North Shore market, read daily. Homes introduced carefully.
      </p>
      <div class="scroll-cue fade-up">This morning's market</div>
    </div>
  </section>

  <!-- ═══ 1 · THIS MORNING'S MARKET — the moment no competitor can copy ═══ -->
  <section class="chapter mv" id="mv1" data-chapter="1" data-palette="0.45">
    <div class="inner">
      <span class="mv-eyebrow fade-up">01 &middot; This morning's market</span>
      <h2 class="headline" data-headline="">The market doesn't reward intuition.<br>It rewards <em>reconciliation</em>.</h2>
      <p class="lede fade-up">Every metric below is pulled from the MLS and reconciled daily — the same numbers that open every listing call.</p>
      <div class="kpi-row fade-up">
        <div class="kpi2"><span class="l">Median Sale &middot; 30d</span><span class="v" id="k-med">—</span><span class="d">Median of the seven village medians</span></div>
        <div class="kpi2"><span class="l">Closed Sales &middot; 30d</span><span class="v" id="k-closed">—</span><span class="d">Across the corridor</span></div>
        <div class="kpi2"><span class="l">Months of Supply</span><span class="v" id="k-supply">—</span><span class="d">Corridor median &middot; under 4 favors sellers</span></div>
      </div>
      <div class="spark-wrap fade-up">
        <span class="l">Corridor median &middot; trailing weeks</span>
        <svg id="spark" viewBox="0 0 600 64" preserveAspectRatio="none" aria-label="Corridor median price trend sparkline"></svg>
      </div>
      <div class="fade-up">
        <span class="asof" id="asof">Data as of —</span>
      </div>
      <hr class="mv-rule fade-up">
      <a class="mv-link fade-up" href="/intelligence">Read the full briefing &rarr;</a>
    </div>
  </section>

  <!-- ═══ 2 · WHO ═══ -->
  <section class="chapter mv" id="mv2" data-chapter="2" data-palette="0.30">
    <div class="inner">
      <span class="mv-eyebrow fade-up">02 &middot; The advisor</span>
      <div class="who-grid fade-up">
        <img src="/images/patrick-headshot.jpg" alt="Patrick Milhaupt, Global Advisor, Jameson Sotheby's International Realty" loading="lazy">
        <div>
          <h2 class="headline" data-headline="">Nine years institutional.<br>A decade on the <em>North Shore</em>.</h2>
          <p class="lede">Patrick Milhaupt spent nine years underwriting more than $500 million in institutional portfolios before joining Sotheby's International Realty in 2016 — and brings that discipline to pricing, marketing, and negotiating architecturally significant homes.</p>
          <hr class="mv-rule">
          <a class="mv-link" href="/about">The full profile &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 3 · HOW ═══ -->
  <section class="chapter mv" id="mv3" data-chapter="3" data-palette="0.55">
    <div class="inner">
      <span class="mv-eyebrow fade-up">03 &middot; The discipline</span>
      <h2 class="headline" data-headline="">Six steps. Each has a checklist.<br>None gets <em>skipped</em>.</h2>
      <div class="steps-rail fade-up">
        <div class="step2"><span class="n">01</span><div class="t">Provenance research</div></div>
        <div class="step2"><span class="n">02</span><div class="t">Reconciled pricing</div></div>
        <div class="step2"><span class="n">03</span><div class="t">Photography &amp; narrative</div></div>
        <div class="step2"><span class="n">04</span><div class="t">Pre-market window</div></div>
        <div class="step2"><span class="n">05</span><div class="t">Global syndication</div></div>
        <div class="step2"><span class="n">06</span><div class="t">Negotiation &amp; close audit</div></div>
      </div>
      <hr class="mv-rule fade-up">
      <a class="mv-link fade-up" href="/selling">How a home is represented &rarr;</a>
    </div>
  </section>

  <!-- ═══ 4 · ACCESS — the signature line lives here, once ═══ -->
  <section class="chapter mv" id="mv4" data-chapter="4" data-palette="0.70">
    <div class="inner" style="text-align:center;">
      <span class="mv-eyebrow fade-up">04 &middot; Access</span>
      <h2 class="headline" data-headline="">The best homes here are never sold —<br>they're <em>introduced</em>.</h2>
      <p class="lede fade-up" style="margin-left:auto;margin-right:auto;">Seven to ten days of private exposure inside the Sotheby's pre-market network, frequently enough to find the buyer before a listing ever goes broadly live.</p>
      <hr class="mv-rule fade-up" style="margin-left:auto;margin-right:auto;">
      <a class="mv-link fade-up" href="/buying">The market before the market &rarr;</a>
    </div>
  </section>

  <!-- ═══ 5 · PROOF — quiet, dated, verifiable ═══ -->
  <section class="chapter mv" id="mv5" data-chapter="5" data-palette="0.85">
    <div class="inner">
      <span class="mv-eyebrow fade-up">05 &middot; On the record</span>
      <div class="outcome fade-up"><b>2024:</b> $13.1M closed volume &middot; $2.02M average price &middot; RealTrends Verified Top Agent</div>
      <div class="press2 fade-up">
        <div class="q">&ldquo;Former Motorola exec lists Lake Forest mansion for almost $13 million&rdquo;</div>
        <div class="s">Crain's Chicago Business &middot; March 2024</div>
      </div>
      <div class="press2 fade-up">
        <div class="q">&ldquo;We've got a lot of Bears players, several of which are my clients.&rdquo;</div>
        <div class="s">Patrick Milhaupt, quoted in The Real Deal &middot; September 2024</div>
      </div>
      <!-- TESTIMONIALS: slot reserved — real client quotes pending, never invented. -->
    </div>
  </section>

  <!-- ═══ 6 · WHERE ═══ -->
  <section class="chapter mv" id="mv6" data-chapter="6" data-palette="0.60">
    <div class="inner">
      <span class="mv-eyebrow fade-up">06 &middot; The corridor</span>
      <h2 class="headline" data-headline="">Eighteen miles of coastline.<br>Seven <em>villages</em>.</h2>
      <div class="villages2 fade-up">
        <a href="/neighborhoods/lake-forest"><span class="vn">Lake Forest</span><span class="vd">Estate scale</span></a>
        <a href="/neighborhoods/winnetka"><span class="vn">Winnetka</span><span class="vd">Walk-to-lake</span></a>
        <a href="/neighborhoods/kenilworth"><span class="vn">Kenilworth</span><span class="vd">Smallest &middot; rarest</span></a>
        <a href="/neighborhoods/glencoe"><span class="vn">Glencoe</span><span class="vd">Ravine &amp; lakefront</span></a>
        <a href="/neighborhoods/wilmette"><span class="vn">Wilmette</span><span class="vd">Village energy</span></a>
        <a href="/neighborhoods/highland-park"><span class="vn">Highland Park</span><span class="vd">Beachfront</span></a>
        <span><span class="vn">Lake Bluff</span><span class="vd">Profile forthcoming</span></span>
      </div>
      <hr class="mv-rule fade-up">
      <a class="mv-link fade-up" href="/neighborhoods">Every village, with live data &rarr;</a>
    </div>
  </section>

  <!-- ═══ 7 · INVITATION ═══ -->
  <section class="chapter mv" id="mv7" data-chapter="7" data-palette="0.35">
    <div class="inner">
      <span class="mv-eyebrow fade-up">07 &middot; Begin</span>
      <h2 class="headline" data-headline="">Thirty minutes.<br>No <em>pitch</em>.</h2>
      <p class="lede fade-up" style="text-align:center;">A direct conversation about what you're trying to do — and an honest read on whether I'm the right advisor for it.</p>
      <div class="invite-row fade-up">
        <a class="invite-btn solid" href="/contact">Send a message</a>
        <a class="invite-btn" href="tel:+18478499828">(847) 849-9828</a>
        <a class="invite-btn" href="mailto:pmilhaupt@jamesonsir.com">Email Patrick</a>
      </div>
    </div>
  </section>

  <script slot="scripts" is:inline>
  /* Movement 1 — honest-dated KPIs + sparkline. One 280-row fetch, no chart library. */
  (function () {
    var URL = 'https://itupjrknklzvmmqicuyc.supabase.co/rest/v1/daily_snapshots' +
      '?select=village,snapshot_date,trailing30_median_price,trailing30_closed_sales,months_supply' +
      '&order=snapshot_date.desc&limit=280';
    var KEY = 'sb_publishable_fQnZLJnaC-dAHBuGBHJgjQ_RUHCe_7S';
    function median(a) { if (!a.length) return null; a = a.slice().sort(function(x,y){return x-y;});
      var m = Math.floor(a.length/2); return a.length % 2 ? a[m] : (a[m-1]+a[m])/2; }
    function fmtM(v) { return v >= 1e6 ? '$' + (v/1e6).toFixed(2) + 'M' : '$' + Math.round(v/1e3) + 'K'; }
    fetch(URL, { headers: { apikey: KEY, Authorization: 'Bearer ' + KEY } })
      .then(function(r){ if (!r.ok) throw new Error(r.status); return r.json(); })
      .then(function(rows) {
        if (!rows.length) throw new Error('empty');
        var byDate = {};
        rows.forEach(function(r) {
          (byDate[r.snapshot_date] = byDate[r.snapshot_date] || []).push(r);
        });
        var dates = Object.keys(byDate).sort();
        var latest = dates[dates.length - 1];
        var todays = byDate[latest];
        var med = median(todays.map(function(r){ return Number(r.trailing30_median_price); }).filter(Boolean));
        var closed = todays.reduce(function(s,r){ return s + (Number(r.trailing30_closed_sales)||0); }, 0);
        var sup = median(todays.map(function(r){ return Number(r.months_supply); }).filter(Boolean));
        document.getElementById('k-med').textContent = med ? fmtM(med) : '—';
        document.getElementById('k-closed').textContent = closed || '—';
        document.getElementById('k-supply').textContent = sup != null ? sup.toFixed(1) + ' mo' : '—';
        var nd = new Date(latest + 'T12:00:00');
        var age = Math.floor((Date.now() - nd.getTime()) / 86400000);
        var asof = document.getElementById('asof');
        asof.innerHTML = 'Data as of <b>' + nd.toLocaleDateString(undefined, { weekday:'short', month:'short', day:'numeric' }) + '</b>' +
          (age > 2 ? ' &middot; last reconciled ' + age + ' days ago' : ' &middot; reconciled daily from the MLS');
        /* sparkline of corridor median per day */
        var pts = dates.map(function(d) {
          return median(byDate[d].map(function(r){ return Number(r.trailing30_median_price); }).filter(Boolean));
        }).filter(function(v){ return v != null; });
        if (pts.length > 2) {
          var mn = Math.min.apply(null, pts), mx = Math.max.apply(null, pts), rg = (mx - mn) || 1;
          var W = 600, H = 64, P = 6;
          var poly = pts.map(function(v, i) {
            var x = P + i * (W - 2*P) / (pts.length - 1);
            var y = H - P - (v - mn) * (H - 2*P) / rg;
            return x.toFixed(1) + ',' + y.toFixed(1);
          }).join(' ');
          var svg = document.getElementById('spark');
          svg.innerHTML =
            '<polyline points="' + poly + '" fill="none" stroke="#C2A265" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/>' +
            '<circle r="3" fill="#EAD9AE" cx="' + poly.split(' ').pop().split(',')[0] + '" cy="' + poly.split(' ').pop().split(',')[1] + '"/>';
        }
      })
      .catch(function() {
        document.getElementById('asof').textContent = 'Live data unavailable — the full briefing is on the Intelligence page.';
      });
  })();
  </script>
</Chapter>
