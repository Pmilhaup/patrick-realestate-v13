---
import Chapter from '../layouts/Chapter.astro';
const lds = [{"@context": "https://schema.org", "@type": "Person", "@id": "https://patrick.realestate/#patrick", "name": "Patrick Milhaupt", "url": "https://patrick.realestate/about", "image": "https://patrick.realestate/images/patrick-headshot.jpg", "jobTitle": "Global Advisor, Jameson Sotheby's International Realty", "telephone": "+1-847-849-9828", "email": "pmilhaupt@jamesonsir.com", "alumniOf": [{"@type": "CollegeOrUniversity", "name": "University of Notre Dame"}, {"@type": "CollegeOrUniversity", "name": "University of San Diego"}], "worksFor": {"@type": "RealEstateAgent", "name": "Jameson Sotheby's International Realty"}}, {"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://patrick.realestate/"}, {"@type": "ListItem", "position": 2, "name": "About", "item": "https://patrick.realestate/about"}]}];
---
<Chapter
